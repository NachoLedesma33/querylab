      "html": "<style data-kid=\"0\">\n  @import url('https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@400;500;600&display=swap');\n  @import url('https://cdn.jsdelivr.net/npm/@tabler/icons-webfont/tabler-icons.min.css');\n\n  :root {\n    --bg-navy: #050D1A;\n    --surface-navy: #0A1526;\n    --border-slate: #1E2D4A;\n    --accent-cyan: #00E5FF;\n    --text-main: #A3B8CC;\n    --text-muted: #4B6282;\n  }\n\n  body {\n    margin: 0;\n    padding: 0;\n    background-color: var(--bg-navy);\n    color: var(--text-main);\n    font-family: 'IBM Plex Mono', monospace;\n    overflow: hidden;\n    height: 100vh;\n  }\n\n  /* Scrollbar Styling */\n  ::-webkit-scrollbar { width: 4px; height: 4px; }\n  ::-webkit-scrollbar-track { background: var(--bg-navy); }\n  ::-webkit-scrollbar-thumb { background: var(--border-slate); }\n  ::-webkit-scrollbar-thumb:hover { background: var(--accent-cyan); }\n\n  .panel-border { border: 1px solid var(--border-slate); }\n  .active-border { border: 2px solid var(--accent-cyan); }\n  \n  .ascii-tree-line { color: var(--text-muted); margin-right: 4px; }\n</style>\n\n<div class=\"flex flex-col h-screen select-none\" data-kid=\"1\">\n  \n  <header class=\"h-8 flex items-center justify-between px-3 border-b border-[#1E2D4A] bg-[#050D1A] shrink-0 text-[11px]\" data-kid=\"2\">\n    <div class=\"flex items-center gap-4\" data-kid=\"3\">\n      <div class=\"flex items-center gap-1 font-bold text-[#00E5FF]\" data-kid=\"4\">\n        <i class=\"ti ti-terminal text-[14px]\" data-kid=\"5\"></i>\n        <span data-kid=\"6\">QUERYLAB</span>\n      </div>\n      <div class=\"flex items-center gap-2 text-[#4B6282]\" data-kid=\"7\">\n        <span data-kid=\"8\">/</span>\n        <span data-kid=\"9\">SQL</span>\n        <span data-kid=\"10\">/</span>\n        <span class=\"text-[#A3B8CC]\" data-kid=\"11\">POSTGRESQL</span>\n      </div>\n    </div>\n    \n    <div class=\"flex items-center gap-4\" data-kid=\"12\">\n      <button class=\"hover:text-[#00E5FF] cursor-pointer\" data-kid=\"13\">[ RUN ]</button>\n      <button class=\"hover:text-[#00E5FF] cursor-pointer\" data-kid=\"14\">[ FORMAT ]</button>\n      <button class=\"hover:text-[#00E5FF] cursor-pointer\" data-kid=\"15\">[ THEME ]</button>\n      <button class=\"hover:text-[#00E5FF] cursor-pointer\" data-kid=\"16\">[ SOUND: ON ]</button>\n      <div class=\"w-px h-3 bg-[#1E2D4A]\" data-kid=\"17\"></div>\n      <div class=\"flex items-center gap-2\" data-kid=\"18\">\n        <i class=\"ti ti-keyboard text-[14px]\" data-kid=\"19\"></i>\n        <span class=\"text-[#4B6282]\" data-kid=\"20\">CTRL+ENTER</span>\n      </div>\n    </div>\n  </header>\n\n  \n  <main class=\"flex flex-1 overflow-hidden\" data-kid=\"21\">\n    \n    <aside class=\"w-12 border-r border-[#1E2D4A] bg-[#050D1A] flex flex-col items-center py-4 gap-6 shrink-0\" data-kid=\"22\">\n      <i class=\"ti ti-database text-[20px] text-[#00E5FF] cursor-pointer\" data-kid=\"23\"></i>\n      <i class=\"ti ti-history text-[20px] text-[#4B6282] hover:text-[#A3B8CC] cursor-pointer\" data-kid=\"24\"></i>\n      <i class=\"ti ti-settings text-[20px] text-[#4B6282] hover:text-[#A3B8CC] cursor-pointer mt-auto\" data-kid=\"25\"></i>\n    </aside>\n\n    \n    <aside class=\"w-64 border-r border-[#1E2D4A] bg-[#0A1526] flex flex-col shrink-0\" data-kid=\"26\">\n      <div class=\"h-8 flex items-center px-3 border-b border-[#1E2D4A] text-[10px] font-bold tracking-widest text-[#4B6282] uppercase\" data-kid=\"27\">\n        Explorer: Schema\n      </div>\n      <div class=\"flex-1 overflow-y-auto p-3 text-[12px] leading-relaxed\" data-kid=\"28\">\n        <div class=\"mb-4\" data-kid=\"29\">\n          <div class=\"flex items-center text-[#00E5FF] mb-1\" data-kid=\"30\">\n            <span class=\"ascii-tree-line\" data-kid=\"31\">[-]</span>\n            <span data-kid=\"32\">public</span>\n          </div>\n          <div class=\"pl-4\" data-kid=\"33\">\n            <div class=\"flex items-center hover:bg-[#1E2D4A] px-1 group cursor-pointer\" data-kid=\"34\">\n              <span class=\"ascii-tree-line\" data-kid=\"35\">+--</span>\n              <span class=\"group-hover:text-[#00E5FF]\" data-kid=\"36\">users</span>\n            </div>\n            <div class=\"pl-8 text-[#4B6282] text-[11px]\" data-kid=\"37\">\n              <div data-kid=\"38\">|   id (uuid)</div>\n              <div data-kid=\"39\">|   email (varchar)</div>\n              <div data-kid=\"40\">|   created_at (timestamp)</div>\n            </div>\n            <div class=\"flex items-center hover:bg-[#1E2D4A] px-1 group cursor-pointer\" data-kid=\"41\">\n              <span class=\"ascii-tree-line\" data-kid=\"42\">+--</span>\n              <span class=\"group-hover:text-[#00E5FF]\" data-kid=\"43\">orders</span>\n            </div>\n            <div class=\"flex items-center hover:bg-[#1E2D4A] px-1 group cursor-pointer\" data-kid=\"44\">\n              <span class=\"ascii-tree-line\" data-kid=\"45\">+--</span>\n              <span class=\"group-hover:text-[#00E5FF]\" data-kid=\"46\">products</span>\n            </div>\n            <div class=\"flex items-center hover:bg-[#1E2D4A] px-1 group cursor-pointer\" data-kid=\"47\">\n              <span class=\"ascii-tree-line\" data-kid=\"48\">+--</span>\n              <span class=\"group-hover:text-[#00E5FF]\" data-kid=\"49\">inventory</span>\n            </div>\n          </div>\n        </div>\n        \n        <div class=\"mt-8\" data-kid=\"50\">\n          <div class=\"flex items-center text-[#4B6282] mb-1\" data-kid=\"51\">\n            <span class=\"ascii-tree-line\" data-kid=\"52\">[+]</span>\n            <span data-kid=\"53\">analytics</span>\n          </div>\n        </div>\n      </div>\n    </aside>\n\n    \n    <section class=\"flex-1 flex flex-col overflow-hidden bg-[#050D1A]\" data-kid=\"54\">\n      \n      <div class=\"flex-1 relative flex flex-col\" data-kid=\"55\">\n        <div class=\"h-8 flex items-center px-3 border-b border-[#1E2D4A] bg-[#0A1526] justify-between\" data-kid=\"56\">\n          <div class=\"flex gap-4 text-[10px] font-bold\" data-kid=\"57\">\n            <span class=\"text-[#00E5FF] border-b border-[#00E5FF] h-8 flex items-center\" data-kid=\"58\">QUERY_01.SQL</span>\n            <span class=\"text-[#4B6282] h-8 flex items-center hover:text-[#A3B8CC] cursor-pointer\" data-kid=\"59\">QUERY_02.SQL</span>\n          </div>\n        </div>\n        \n        <div class=\"flex-1 p-4 text-[14px] font-mono leading-relaxed overflow-hidden\" data-kid=\"60\">\n          <div class=\"flex\" data-kid=\"61\">\n            <div class=\"w-8 text-[#4B6282] text-right pr-3 select-none\" data-kid=\"62\">1</div>\n            <div data-kid=\"63\"><span class=\"text-[#FF79C6]\" data-kid=\"64\">SELECT</span> u.email, count(o.id) <span class=\"text-[#FF79C6]\" data-kid=\"65\">AS</span> order_count</div>\n          </div>\n          <div class=\"flex\" data-kid=\"66\">\n            <div class=\"w-8 text-[#4B6282] text-right pr-3 select-none\" data-kid=\"67\">2</div>\n            <div data-kid=\"68\"><span class=\"text-[#FF79C6]\" data-kid=\"69\">FROM</span> users u</div>\n          </div>\n          <div class=\"flex\" data-kid=\"70\">\n            <div class=\"w-8 text-[#4B6282] text-right pr-3 select-none\" data-kid=\"71\">3</div>\n            <div data-kid=\"72\"><span class=\"text-[#FF79C6]\" data-kid=\"73\">LEFT JOIN</span> orders o <span class=\"text-[#FF79C6]\" data-kid=\"74\">ON</span> u.id = o.user_id</div>\n          </div>\n          <div class=\"flex\" data-kid=\"75\">\n            <div class=\"w-8 text-[#4B6282] text-right pr-3 select-none\" data-kid=\"76\">4</div>\n            <div data-kid=\"77\"><span class=\"text-[#FF79C6]\" data-kid=\"78\">WHERE</span> u.created_at > <span class=\"text-[#F1FA8C]\" data-kid=\"79\">'2023-01-01'</span></div>\n          </div>\n          <div class=\"flex\" data-kid=\"80\">\n            <div class=\"w-8 text-[#4B6282] text-right pr-3 select-none\" data-kid=\"81\">5</div>\n            <div data-kid=\"82\"><span class=\"text-[#FF79C6]\" data-kid=\"83\">GROUP BY</span> u.email</div>\n          </div>\n          <div class=\"flex\" data-kid=\"84\">\n            <div class=\"w-8 text-[#4B6282] text-right pr-3 select-none\" data-kid=\"85\">6</div>\n            <div data-kid=\"86\"><span class=\"text-[#FF79C6]\" data-kid=\"87\">HAVING</span> count(o.id) > <span class=\"text-[#BD93F9]\" data-kid=\"88\">5</span></div>\n          </div>\n          <div class=\"flex\" data-kid=\"89\">\n            <div class=\"w-8 text-[#4B6282] text-right pr-3 select-none\" data-kid=\"90\">7</div>\n            <div data-kid=\"91\"><span class=\"text-[#FF79C6]\" data-kid=\"92\">ORDER BY</span> order_count <span class=\"text-[#FF79C6]\" data-kid=\"93\">DESC</span>;</div>\n          </div>\n          <div class=\"flex\" data-kid=\"94\">\n            <div class=\"w-8 text-[#4B6282] text-right pr-3 select-none\" data-kid=\"95\">8</div>\n            <div class=\"animate-pulse w-2 h-5 bg-[#00E5FF] ml-1 opacity-50\" data-kid=\"96\"></div>\n          </div>\n        </div>\n\n        \n        <div class=\"h-6 bg-[#00E5FF] text-[#050D1A] flex items-center justify-between px-3 text-[10px] font-bold\" data-kid=\"97\">\n          <div class=\"flex gap-4\" data-kid=\"98\">\n            <span data-kid=\"99\">LN 8, COL 1</span>\n            <span data-kid=\"100\">SPACES: 2</span>\n            <span data-kid=\"101\">UTF-8</span>\n          </div>\n          <div class=\"flex gap-4\" data-kid=\"102\">\n            <span data-kid=\"103\">POSTGRESQL</span>\n            <i class=\"ti ti-check text-[12px]\" data-kid=\"104\"></i>\n          </div>\n        </div>\n      </div>\n\n      \n      <div class=\"h-[45%] border-t-2 border-[#00E5FF] bg-[#0A1526] flex flex-col shadow-[0_-10px_30px_rgba(0,229,255,0.05)]\" data-kid=\"105\">\n        <div class=\"h-8 flex items-center justify-between px-3 border-b border-[#1E2D4A] bg-[#050D1A]\" data-kid=\"106\">\n          <div class=\"flex gap-6 text-[10px] font-bold\" data-kid=\"107\">\n            <div class=\"flex items-center gap-2 text-[#00E5FF]\" data-kid=\"108\">\n              <i class=\"ti ti-table text-[14px]\" data-kid=\"109\"></i>\n              <span data-kid=\"110\">RESULTS</span>\n            </div>\n            <div class=\"flex items-center gap-2 text-[#4B6282] hover:text-[#A3B8CC] cursor-pointer\" data-kid=\"111\">\n              <i class=\"ti ti-chart-dots text-[14px]\" data-kid=\"112\"></i>\n              <span data-kid=\"113\">VISUALIZER</span>\n            </div>\n            <div class=\"flex items-center gap-2 text-[#4B6282] hover:text-[#A3B8CC] cursor-pointer\" data-kid=\"114\">\n              <i class=\"ti ti-history text-[14px]\" data-kid=\"115\"></i>\n              <span data-kid=\"116\">PLAN (EXPLAIN)</span>\n            </div>\n          </div>\n          \n          <div class=\"flex items-center gap-4 text-[10px]\" data-kid=\"117\">\n            <span class=\"text-[#4B6282]\" data-kid=\"118\">EXECUTION: <span class=\"text-[#00E5FF]\" data-kid=\"119\">12ms</span></span>\n            <span class=\"text-[#4B6282]\" data-kid=\"120\">ROWS: <span class=\"text-[#00E5FF]\" data-kid=\"121\">42</span></span>\n            <div class=\"flex gap-1\" data-kid=\"122\">\n              <button class=\"bg-[#1E2D4A] px-2 py-0.5 hover:bg-[#00E5FF] hover:text-[#050D1A] transition-colors cursor-pointer\" data-kid=\"123\">CSV</button>\n              <button class=\"bg-[#1E2D4A] px-2 py-0.5 hover:bg-[#00E5FF] hover:text-[#050D1A] transition-colors cursor-pointer\" data-kid=\"124\">JSON</button>\n            </div>\n          </div>\n        </div>\n\n        \n        <div class=\"flex-1 overflow-auto bg-[#050D1A]\" data-kid=\"125\">\n          <table class=\"w-full border-collapse text-[11px]\" data-kid=\"126\">\n            <thead data-kid=\"127\">\n              <tr class=\"bg-[#0A1526] sticky top-0 z-10\" data-kid=\"128\">\n                <th class=\"border border-[#1E2D4A] p-2 text-left text-[#4B6282] font-bold w-12 text-center\" data-kid=\"129\">#</th>\n                <th class=\"border border-[#1E2D4A] p-2 text-left text-[#00E5FF] font-bold tracking-wider\" data-kid=\"130\">EMAIL</th>\n                <th class=\"border border-[#1E2D4A] p-2 text-left text-[#00E5FF] font-bold tracking-wider\" data-kid=\"131\">ORDER_COUNT</th>\n                <th class=\"border border-[#1E2D4A] p-2 text-left text-[#00E5FF] font-bold tracking-wider\" data-kid=\"132\">LAST_ORDER</th>\n                <th class=\"border border-[#1E2D4A] p-2 text-left text-[#00E5FF] font-bold tracking-wider\" data-kid=\"133\">STATUS</th>\n              </tr>\n            </thead>\n            <tbody data-kid=\"134\">\n              <tr class=\"hover:bg-[#1E2D4A]/30 transition-colors\" data-kid=\"135\">\n                <td class=\"border border-[#1E2D4A] p-2 text-center text-[#4B6282]\" data-kid=\"136\">1</td>\n                <td class=\"border border-[#1E2D4A] p-2\" data-kid=\"137\">alex.rivera@example.com</td>\n                <td class=\"border border-[#1E2D4A] p-2 text-[#00E5FF]\" data-kid=\"138\">14</td>\n                <td class=\"border border-[#1E2D4A] p-2\" data-kid=\"139\">2023-06-12 14:22</td>\n                <td class=\"border border-[#1E2D4A] p-2\" data-kid=\"140\"><span class=\"text-[#50FA7B]\" data-kid=\"141\">[ACTIVE]</span></td>\n              </tr>\n              <tr class=\"hover:bg-[#1E2D4A]/30 transition-colors\" data-kid=\"142\">\n                <td class=\"border border-[#1E2D4A] p-2 text-center text-[#4B6282]\" data-kid=\"143\">2</td>\n                <td class=\"border border-[#1E2D4A] p-2 border-2 border-[#00E5FF] relative\" data-kid=\"144\">\n                  sarah.chen@devmail.org\n                  <div class=\"absolute -top-1 -right-1 w-2 h-2 bg-[#00E5FF]\" data-kid=\"145\"></div>\n                </td>\n                <td class=\"border border-[#1E2D4A] p-2 text-[#00E5FF]\" data-kid=\"146\">12</td>\n                <td class=\"border border-[#1E2D4A] p-2\" data-kid=\"147\">2023-06-11 09:45</td>\n                <td class=\"border border-[#1E2D4A] p-2\" data-kid=\"148\"><span class=\"text-[#50FA7B]\" data-kid=\"149\">[ACTIVE]</span></td>\n              </tr>\n              <tr class=\"hover:bg-[#1E2D4A]/30 transition-colors\" data-kid=\"150\">\n                <td class=\"border border-[#1E2D4A] p-2 text-center text-[#4B6282]\" data-kid=\"151\">3</td>\n                <td class=\"border border-[#1E2D4A] p-2\" data-kid=\"152\">j.smith@corporate.net</td>\n                <td class=\"border border-[#1E2D4A] p-2 text-[#00E5FF]\" data-kid=\"153\">9</td>\n                <td class=\"border border-[#1E2D4A] p-2\" data-kid=\"154\">2023-06-10 22:10</td>\n                <td class=\"border border-[#1E2D4A] p-2\" data-kid=\"155\"><span class=\"text-[#FFB86C]\" data-kid=\"156\">[PENDING]</span></td>\n              </tr>\n              <tr class=\"hover:bg-[#1E2D4A]/30 transition-colors\" data-kid=\"157\">\n                <td class=\"border border-[#1E2D4A] p-2 text-center text-[#4B6282]\" data-kid=\"158\">4</td>\n                <td class=\"border border-[#1E2D4A] p-2\" data-kid=\"159\">monica.beltran@studio.io</td>\n                <td class=\"border border-[#1E2D4A] p-2 text-[#00E5FF]\" data-kid=\"160\">8</td>\n                <td class=\"border border-[#1E2D4A] p-2\" data-kid=\"161\">2023-06-08 11:30</td>\n                <td class=\"border border-[#1E2D4A] p-2\" data-kid=\"162\"><span class=\"text-[#50FA7B]\" data-kid=\"163\">[ACTIVE]</span></td>\n              </tr>\n              <tr class=\"hover:bg-[#1E2D4A]/30 transition-colors\" data-kid=\"164\">\n                <td class=\"border border-[#1E2D4A] p-2 text-center text-[#4B6282]\" data-kid=\"165\">5</td>\n                <td class=\"border border-[#1E2D4A] p-2\" data-kid=\"166\">k.watanabe@tech.jp</td>\n                <td class=\"border border-[#1E2D4A] p-2 text-[#00E5FF]\" data-kid=\"167\">7</td>\n                <td class=\"border border-[#1E2D4A] p-2\" data-kid=\"168\">2023-06-05 18:05</td>\n                <td class=\"border border-[#1E2D4A] p-2\" data-kid=\"169\"><span class=\"text-[#FF5555]\" data-kid=\"170\">[FLAGGED]</span></td>\n              </tr>\n              <tr class=\"hover:bg-[#1E2D4A]/30 transition-colors\" data-kid=\"171\">\n                <td class=\"border border-[#1E2D4A] p-2 text-center text-[#4B6282]\" data-kid=\"172\">6</td>\n                <td class=\"border border-[#1E2D4A] p-2\" data-kid=\"173\">d.rossi@design.it</td>\n                <td class=\"border border-[#1E2D4A] p-2 text-[#00E5FF]\" data-kid=\"174\">6</td>\n                <td class=\"border border-[#1E2D4A] p-2\" data-kid=\"175\">2023-06-01 10:15</td>\n                <td class=\"border border-[#1E2D4A] p-2\" data-kid=\"176\"><span class=\"text-[#50FA7B]\" data-kid=\"177\">[ACTIVE]</span></td>\n              </tr>\n            </tbody>\n          </table>\n        </div>\n\n        \n        <div class=\"h-8 border-t border-[#1E2D4A] bg-[#050D1A] flex items-center justify-between px-3 text-[10px] font-bold\" data-kid=\"178\">\n          <div class=\"text-[#4B6282]\" data-kid=\"179\">SHOWING 1-10 OF 42</div>\n          <div class=\"flex items-center gap-1\" data-kid=\"180\">\n            <button class=\"w-6 h-6 flex items-center justify-center border border-[#1E2D4A] hover:bg-[#00E5FF] hover:text-[#050D1A] cursor-pointer\" data-kid=\"181\">|&lt;</button>\n            <button class=\"w-6 h-6 flex items-center justify-center border border-[#1E2D4A] hover:bg-[#00E5FF] hover:text-[#050D1A] cursor-pointer\" data-kid=\"182\">&lt;</button>\n            <button class=\"w-6 h-6 flex items-center justify-center border border-[#00E5FF] bg-[#00E5FF] text-[#050D1A] cursor-pointer\" data-kid=\"183\">1</button>\n            <button class=\"w-6 h-6 flex items-center justify-center border border-[#1E2D4A] hover:bg-[#00E5FF] hover:text-[#050D1A] cursor-pointer\" data-kid=\"184\">2</button>\n            <button class=\"w-6 h-6 flex items-center justify-center border border-[#1E2D4A] hover:bg-[#00E5FF] hover:text-[#050D1A] cursor-pointer\" data-kid=\"185\">3</button>\n            <button class=\"w-6 h-6 flex items-center justify-center border border-[#1E2D4A] hover:bg-[#00E5FF] hover:text-[#050D1A] cursor-pointer\" data-kid=\"186\">4</button>\n            <button class=\"w-6 h-6 flex items-center justify-center border border-[#1E2D4A] hover:bg-[#00E5FF] hover:text-[#050D1A] cursor-pointer\" data-kid=\"187\">5</button>\n            <button class=\"w-6 h-6 flex items-center justify-center border border-[#1E2D4A] hover:bg-[#00E5FF] hover:text-[#050D1A] cursor-pointer\" data-kid=\"188\">&gt;</button>\n            <button class=\"w-6 h-6 flex items-center justify-center border border-[#1E2D4A] hover:bg-[#00E5FF] hover:text-[#050D1A] cursor-pointer\" data-kid=\"189\">&gt;|</button>\n          </div>\n        </div>\n      </div>\n    </section>\n  </main>\n</div>",
