      "html": "<style data-kid=\"0\">\n  @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700&family=JetBrains+Mono:wght@400;500&display=swap');\n  @import url('https://cdn.jsdelivr.net/npm/@tabler/icons-webfont/tabler-icons.min.css');\n\n  :root {\n    --bg-primary: #000000;\n    --bg-secondary: #0A0A0A;\n    --border-color: #333333;\n    --accent-color: #FFF000;\n    --text-primary: #EDEDED;\n    --text-muted: #888888;\n  }\n\n  body {\n    background-color: var(--bg-primary);\n    color: var(--text-primary);\n    font-family: 'Inter', sans-serif;\n    margin: 0;\n    overflow: hidden;\n  }\n\n  .font-mono {\n    font-family: 'JetBrains Mono', monospace;\n  }\n\n  /* Custom Scrollbar */\n  ::-webkit-scrollbar {\n    width: 6px;\n    height: 6px;\n  }\n  ::-webkit-scrollbar-track {\n    background: var(--bg-primary);\n  }\n  ::-webkit-scrollbar-thumb {\n    background: var(--border-color);\n  }\n  ::-webkit-scrollbar-thumb:hover {\n    background: #555555;\n  }\n</style>\n\n<div class=\"h-screen flex flex-col border-white/5\" data-kid=\"1\">\n  \n  <header class=\"h-14 border-b border-[#333333] flex items-center justify-between px-6 bg-black z-20\" data-kid=\"2\">\n    <div class=\"flex items-center gap-3\" data-kid=\"3\">\n      <i class=\"ti ti-terminal-square text-[#FFF000] text-xl\" data-kid=\"4\"></i>\n      <span class=\"font-bold tracking-tight lowercase text-lg\" data-kid=\"5\">querylab</span>\n    </div>\n\n    \n    <div class=\"flex items-center bg-[#1A1A1A] p-1 rounded-none border border-[#333333]\" data-kid=\"6\">\n      <button class=\"px-4 py-1 text-xs font-bold bg-[#FFF000] text-black uppercase tracking-wider\" data-kid=\"7\">SQL</button>\n      <button class=\"px-4 py-1 text-xs font-bold text-[#888888] uppercase tracking-wider hover:text-white transition-colors\" data-kid=\"8\">GraphQL</button>\n    </div>\n\n    <div class=\"flex items-center gap-4\" data-kid=\"9\">\n      <button class=\"w-8 h-8 flex items-center justify-center border border-[#333333] hover:text-[#FFF000] transition-colors\" data-kid=\"10\">\n        <i class=\"ti ti-sun-moon\" data-kid=\"11\"></i>\n      </button>\n      <button class=\"w-8 h-8 flex items-center justify-center border border-[#333333] hover:text-[#FFF000] transition-colors\" data-kid=\"12\">\n        <i class=\"ti ti-keyboard\" data-kid=\"13\"></i>\n      </button>\n      <div class=\"h-6 w-[1px] bg-[#333333] mx-1\" data-kid=\"14\"></div>\n      <button class=\"px-3 py-1 text-[10px] font-bold border border-[#333333] uppercase tracking-widest text-[#888888]\" data-kid=\"15\">\n        Presentation\n      </button>\n    </div>\n  </header>\n\n  \n  <div class=\"flex-1 flex overflow-hidden\" data-kid=\"16\">\n    \n    <aside class=\"w-72 border-r border-[#333333] flex flex-col bg-black\" data-kid=\"17\">\n      \n      <div class=\"flex border-b border-[#333333]\" data-kid=\"18\">\n        <button class=\"flex-1 py-3 text-[10px] font-bold uppercase tracking-widest border-b-2 border-[#FFF000] text-white\" data-kid=\"19\">Schema</button>\n        <button class=\"flex-1 py-3 text-[10px] font-bold uppercase tracking-widest border-b-2 border-transparent text-[#888888] hover:text-white\" data-kid=\"20\">History</button>\n      </div>\n\n      \n      <div class=\"p-4 border-b border-[#333333]\" data-kid=\"21\">\n        <div class=\"relative group\" data-kid=\"22\">\n          <i class=\"ti ti-search absolute left-3 top-1/2 -translate-y-1/2 text-[#555555] group-focus-within:text-[#FFF000]\" data-kid=\"23\"></i>\n          <input type=\"text\" placeholder=\"SEARCH TABLES...\" class=\"w-full bg-[#0A0A0A] border border-[#333333] py-2 pl-9 pr-4 text-[11px] font-mono focus:outline-none focus:border-[#FFF000] transition-colors placeholder:text-[#444444]\" data-kid=\"24\">\n        </div>\n      </div>\n\n      \n      <div class=\"flex-1 overflow-y-auto scrollbar-thin\" data-kid=\"25\">\n        <div class=\"py-2\" data-kid=\"26\">\n          \n          <div class=\"group px-4 py-2 flex items-center justify-between hover:bg-[#0A0A0A] cursor-pointer\" data-kid=\"27\">\n            <div class=\"flex items-center gap-3\" data-kid=\"28\">\n              <i class=\"ti ti-table text-[#FFF000]\" data-kid=\"29\"></i>\n              <span class=\"text-[13px] font-medium\" data-kid=\"30\">users</span>\n            </div>\n            <i class=\"ti ti-play text-[10px] opacity-0 group-hover:opacity-100 text-[#FFF000]\" data-kid=\"31\"></i>\n          </div>\n          \n          <div class=\"bg-[#050505]\" data-kid=\"32\">\n            <div class=\"group px-4 py-2 flex items-center justify-between bg-[#0A0A0A] border-l-2 border-[#FFF000]\" data-kid=\"33\">\n              <div class=\"flex items-center gap-3\" data-kid=\"34\">\n                <i class=\"ti ti-table text-[#FFF000]\" data-kid=\"35\"></i>\n                <span class=\"text-[13px] font-medium\" data-kid=\"36\">transactions</span>\n              </div>\n              <i class=\"ti ti-chevron-down text-[12px] text-[#555555]\" data-kid=\"37\"></i>\n            </div>\n            <div class=\"pl-12 py-1 flex flex-col gap-1.5 border-b border-[#333333] pb-3\" data-kid=\"38\">\n              <div class=\"flex items-center justify-between pr-4 group\" data-kid=\"39\">\n                <span class=\"text-[11px] font-mono text-[#BBBBBB]\" data-kid=\"40\">id</span>\n                <span class=\"text-[9px] font-mono text-[#555555] uppercase tracking-tighter\" data-kid=\"41\">uuid</span>\n              </div>\n              <div class=\"flex items-center justify-between pr-4 group\" data-kid=\"42\">\n                <span class=\"text-[11px] font-mono text-[#BBBBBB]\" data-kid=\"43\">amount</span>\n                <span class=\"text-[9px] font-mono text-[#555555] uppercase tracking-tighter\" data-kid=\"44\">decimal</span>\n              </div>\n              <div class=\"flex items-center justify-between pr-4 group\" data-kid=\"45\">\n                <span class=\"text-[11px] font-mono text-[#BBBBBB]\" data-kid=\"46\">user_id</span>\n                <span class=\"text-[9px] font-mono text-[#555555] uppercase tracking-tighter\" data-kid=\"47\">uuid</span>\n              </div>\n              <div class=\"flex items-center justify-between pr-4 group\" data-kid=\"48\">\n                <span class=\"text-[11px] font-mono text-[#BBBBBB]\" data-kid=\"49\">created_at</span>\n                <span class=\"text-[9px] font-mono text-[#555555] uppercase tracking-tighter\" data-kid=\"50\">timestamp</span>\n              </div>\n            </div>\n          </div>\n          \n          <div class=\"group px-4 py-2 flex items-center justify-between hover:bg-[#0A0A0A] cursor-pointer\" data-kid=\"51\">\n            <div class=\"flex items-center gap-3\" data-kid=\"52\">\n              <i class=\"ti ti-table text-[#888888] group-hover:text-[#FFF000]\" data-kid=\"53\"></i>\n              <span class=\"text-[13px] font-medium text-[#BBBBBB] group-hover:text-white\" data-kid=\"54\">products</span>\n            </div>\n            <i class=\"ti ti-play text-[10px] opacity-0 group-hover:opacity-100 text-[#FFF000]\" data-kid=\"55\"></i>\n          </div>\n          <div class=\"group px-4 py-2 flex items-center justify-between hover:bg-[#0A0A0A] cursor-pointer\" data-kid=\"56\">\n            <div class=\"flex items-center gap-3\" data-kid=\"57\">\n              <i class=\"ti ti-table text-[#888888] group-hover:text-[#FFF000]\" data-kid=\"58\"></i>\n              <span class=\"text-[13px] font-medium text-[#BBBBBB] group-hover:text-white\" data-kid=\"59\">orders</span>\n            </div>\n            <i class=\"ti ti-play text-[10px] opacity-0 group-hover:opacity-100 text-[#FFF000]\" data-kid=\"60\"></i>\n          </div>\n        </div>\n      </div>\n    </aside>\n\n    \n    <main class=\"flex-1 flex flex-col min-w-0 bg-[#000000]\" data-kid=\"61\">\n      \n      <div class=\"flex-1 flex flex-col min-h-0 relative\" data-kid=\"62\">\n        \n        <div class=\"h-12 border-b border-[#333333] flex items-center justify-between px-4 bg-black\" data-kid=\"63\">\n          <div class=\"flex items-center gap-2\" data-kid=\"64\">\n            <span class=\"text-[10px] font-bold uppercase tracking-[0.2em] text-[#555555]\" data-kid=\"65\">Query_01.sql</span>\n          </div>\n          <div class=\"flex items-center gap-2\" data-kid=\"66\">\n            <button class=\"px-4 py-1.5 text-[11px] font-bold text-white border border-[#333333] uppercase tracking-widest hover:bg-[#111111]\" data-kid=\"67\">Format</button>\n            <button class=\"px-4 py-1.5 text-[11px] font-bold text-[#FF4444] border border-[#333333] uppercase tracking-widest hover:bg-[#111111]\" data-kid=\"68\">Clear</button>\n            <div class=\"w-[1px] h-6 bg-[#333333] mx-1\" data-kid=\"69\"></div>\n            <button class=\"px-8 py-1.5 text-[12px] font-bold bg-[#FFF000] text-black uppercase tracking-[0.15em] hover:brightness-110 active:scale-[0.98] transition-all\" data-kid=\"70\">\n              Run\n            </button>\n          </div>\n        </div>\n\n        \n        <div class=\"flex-1 p-6 font-mono text-[13px] leading-relaxed overflow-auto scrollbar-thin\" data-kid=\"71\">\n          <div class=\"flex gap-4\" data-kid=\"72\">\n            <div class=\"text-[#333333] text-right select-none w-8\" data-kid=\"73\">\n              1<br data-kid=\"74\">2<br data-kid=\"75\">3<br data-kid=\"76\">4<br data-kid=\"77\">5\n            </div>\n            <div class=\"flex-1\" data-kid=\"78\">\n              <span class=\"text-[#FF79C6]\" data-kid=\"79\">SELECT</span><br data-kid=\"80\">\n              &nbsp;&nbsp;u.name, <span class=\"text-[#50FA7B]\" data-kid=\"81\">COUNT</span>(t.id) <span class=\"text-[#FF79C6]\" data-kid=\"82\">AS</span> transaction_count,<br data-kid=\"83\">\n              &nbsp;&nbsp;<span class=\"text-[#50FA7B]\" data-kid=\"84\">SUM</span>(t.amount) <span class=\"text-[#FF79C6]\" data-kid=\"85\">AS</span> total_spent<br data-kid=\"86\">\n              <span class=\"text-[#FF79C6]\" data-kid=\"87\">FROM</span> users u<br data-kid=\"88\">\n              <span class=\"text-[#FF79C6]\" data-kid=\"89\">JOIN</span> transactions t <span class=\"text-[#FF79C6]\" data-kid=\"90\">ON</span> u.id = t.user_id<br data-kid=\"91\">\n              <span class=\"text-[#FF79C6]\" data-kid=\"92\">GROUP BY</span> u.id<br data-kid=\"93\">\n              <span class=\"text-[#FF79C6]\" data-kid=\"94\">ORDER BY</span> total_spent <span class=\"text-[#FF79C6]\" data-kid=\"95\">DESC</span>;<br data-kid=\"96\">\n              <span class=\"inline-block w-[1px] h-5 bg-[#FFF000] animate-pulse align-middle\" data-kid=\"97\"></span>\n            </div>\n          </div>\n        </div>\n      </div>\n\n      \n      <div class=\"h-1 bg-[#333333] hover:bg-[#FFF000] cursor-ns-resize transition-colors z-10\" data-kid=\"98\"></div>\n\n      \n      <div class=\"h-[40%] flex flex-col bg-[#050505]\" data-kid=\"99\">\n        \n        <div class=\"flex items-center justify-between border-b border-[#333333] bg-black px-4\" data-kid=\"100\">\n          <div class=\"flex\" data-kid=\"101\">\n            <button class=\"px-6 py-3 text-[10px] font-bold uppercase tracking-widest border-b-2 border-[#FFF000] text-white\" data-kid=\"102\">Results</button>\n            <button class=\"px-6 py-3 text-[10px] font-bold uppercase tracking-widest border-b-2 border-transparent text-[#555555] hover:text-[#888888]\" data-kid=\"103\">Execution Flow</button>\n          </div>\n          <div class=\"flex items-center gap-3\" data-kid=\"104\">\n             <span class=\"text-[9px] font-mono text-[#555555] uppercase tracking-tighter\" data-kid=\"105\">Export:</span>\n             <button class=\"text-[10px] text-[#888888] hover:text-[#FFF000]\" data-kid=\"106\">CSV</button>\n             <button class=\"text-[10px] text-[#888888] hover:text-[#FFF000]\" data-kid=\"107\">JSON</button>\n          </div>\n        </div>\n\n        \n        <div class=\"flex-1 overflow-auto scrollbar-thin\" data-kid=\"108\">\n          <table class=\"w-full text-left border-collapse\" data-kid=\"109\">\n            <thead data-kid=\"110\">\n              <tr class=\"bg-[#0A0A0A] border-b border-[#333333]\" data-kid=\"111\">\n                <th class=\"px-4 py-2 text-[10px] font-bold uppercase tracking-widest text-[#555555] border-r border-[#333333] w-12 text-center\" data-kid=\"112\">#</th>\n                <th class=\"px-4 py-2 text-[10px] font-bold uppercase tracking-widest text-[#555555] border-r border-[#333333]\" data-kid=\"113\">User Name</th>\n                <th class=\"px-4 py-2 text-[10px] font-bold uppercase tracking-widest text-[#555555] border-r border-[#333333]\" data-kid=\"114\">Tx Count</th>\n                <th class=\"px-4 py-2 text-[10px] font-bold uppercase tracking-widest text-[#555555]\" data-kid=\"115\">Total Spent</th>\n              </tr>\n            </thead>\n            <tbody class=\"font-mono text-[12px]\" data-kid=\"116\">\n              <tr class=\"border-b border-[#1A1A1A] hover:bg-[#111111] transition-colors group\" data-kid=\"117\">\n                <td class=\"px-4 py-1.5 text-center text-[#444444] border-r border-[#1A1A1A]\" data-kid=\"118\">1</td>\n                <td class=\"px-4 py-1.5 text-[#EDEDED] border-r border-[#1A1A1A]\" data-kid=\"119\">Alex Rivers</td>\n                <td class=\"px-4 py-1.5 text-[#888888] border-r border-[#1A1A1A]\" data-kid=\"120\">42</td>\n                <td class=\"px-4 py-1.5 text-[#FFF000]\" data-kid=\"121\">$12,450.00</td>\n              </tr>\n              <tr class=\"border-b border-[#1A1A1A] hover:bg-[#111111] transition-colors\" data-kid=\"122\">\n                <td class=\"px-4 py-1.5 text-center text-[#444444] border-r border-[#1A1A1A]\" data-kid=\"123\">2</td>\n                <td class=\"px-4 py-1.5 text-[#EDEDED] border-r border-[#1A1A1A]\" data-kid=\"124\">Jordan Smith</td>\n                <td class=\"px-4 py-1.5 text-[#888888] border-r border-[#1A1A1A]\" data-kid=\"125\">38</td>\n                <td class=\"px-4 py-1.5 text-[#FFF000]\" data-kid=\"126\">$9,230.50</td>\n              </tr>\n              <tr class=\"border-b border-[#1A1A1A] hover:bg-[#111111] transition-colors\" data-kid=\"127\">\n                <td class=\"px-4 py-1.5 text-center text-[#444444] border-r border-[#1A1A1A]\" data-kid=\"128\">3</td>\n                <td class=\"px-4 py-1.5 text-[#EDEDED] border-r border-[#1A1A1A]\" data-kid=\"129\">Maria Garcia</td>\n                <td class=\"px-4 py-1.5 text-[#888888] border-r border-[#1A1A1A]\" data-kid=\"130\">31</td>\n                <td class=\"px-4 py-1.5 text-[#FFF000]\" data-kid=\"131\">$7,812.20</td>\n              </tr>\n              <tr class=\"border-b border-[#1A1A1A] hover:bg-[#111111] transition-colors\" data-kid=\"132\">\n                <td class=\"px-4 py-1.5 text-center text-[#444444] border-r border-[#1A1A1A]\" data-kid=\"133\">4</td>\n                <td class=\"px-4 py-1.5 text-[#EDEDED] border-r border-[#1A1A1A]\" data-kid=\"134\">Sam Wilson</td>\n                <td class=\"px-4 py-1.5 text-[#888888] border-r border-[#1A1A1A]\" data-kid=\"135\">27</td>\n                <td class=\"px-4 py-1.5 text-[#FFF000]\" data-kid=\"136\">$6,100.00</td>\n              </tr>\n              <tr class=\"border-b border-[#1A1A1A] hover:bg-[#111111] transition-colors\" data-kid=\"137\">\n                <td class=\"px-4 py-1.5 text-center text-[#444444] border-r border-[#1A1A1A]\" data-kid=\"138\">5</td>\n                <td class=\"px-4 py-1.5 text-[#EDEDED] border-r border-[#1A1A1A]\" data-kid=\"139\">Chris Lee</td>\n                <td class=\"px-4 py-1.5 text-[#888888] border-r border-[#1A1A1A]\" data-kid=\"140\">19</td>\n                <td class=\"px-4 py-1.5 text-[#FFF000]\" data-kid=\"141\">$4,320.00</td>\n              </tr>\n            </tbody>\n          </table>\n        </div>\n\n        \n        <div class=\"h-8 border-t border-[#333333] bg-black flex items-center justify-between px-4\" data-kid=\"142\">\n          <div class=\"flex items-center gap-4\" data-kid=\"143\">\n            <div class=\"flex items-center gap-2\" data-kid=\"144\">\n              <span class=\"text-[9px] font-bold uppercase tracking-widest text-[#555555]\" data-kid=\"145\">Success</span>\n              <div class=\"w-2 h-2 rounded-full bg-[#50FA7B] shadow-[0_0_8px_rgba(80,250,123,0.5)]\" data-kid=\"146\"></div>\n            </div>\n            <span class=\"text-[9px] font-mono text-[#888888] uppercase\" data-kid=\"147\">124ms</span>\n            <span class=\"text-[9px] font-mono text-[#888888] uppercase\" data-kid=\"148\">5 Rows Returned</span>\n          </div>\n          <div class=\"flex items-center gap-4 text-[9px] font-mono text-[#444444]\" data-kid=\"149\">\n            <span data-kid=\"150\">UTF-8</span>\n            <span data-kid=\"151\">PostgreSQL 14.2</span>\n          </div>\n        </div>\n      </div>\n    </main>\n  </div>\n</div>",
